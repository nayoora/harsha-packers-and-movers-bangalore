# Harsha Packers and Movers - server config (Apache / Hostinger)
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  # Redirect www to non-www (canonical host)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
  # Legacy duplicate quote URL -> canonical quote page
  RewriteRule ^get-a-quote/?$ /get-free-quote-bangalore/ [L,R=301]
</IfModule>

# Custom error page
ErrorDocument 404 /404.html

# Protect captured leads, source, config and backup files from public access
<FilesMatch "\.(csv|json|md|bak|log|sql|sh|yml|yaml|ini|env|map)$">
  Require all denied
</FilesMatch>
# Block hidden/dotfiles (e.g. .git, .htaccess) except the well-known folder
<FilesMatch "^\.(?!well-known)">
  Require all denied
</FilesMatch>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/plain text/xml
</IfModule>

# Browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Always serve fresh HTML (assets are cache-busted with ?v=, so they can cache long)
<IfModule mod_headers.c>
  <FilesMatch ".html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.web3forms.com https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://stats.g.doubleclick.net; frame-src https://www.google.com https://maps.google.com https://www.youtube.com https://www.youtube-nocookie.com; object-src 'none'; worker-src 'self'; manifest-src 'self'; base-uri 'self'; form-action 'self' https://api.web3forms.com; frame-ancestors 'self'"
  Header unset X-Powered-By
</IfModule>

# Image hotlink protection: only this site, search engines & social link-previews may embed images.
# Other websites get a 403, so they can't steal your photos. Empty referer (direct loads) is allowed.
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_REFERER} !^$
  RewriteCond %{HTTP_REFERER} !^https?://(www\.)?harshapackersandmoversbangalore\.com [NC]
  RewriteCond %{HTTP_REFERER} !google\. [NC]
  RewriteCond %{HTTP_REFERER} !bing\. [NC]
  RewriteCond %{HTTP_REFERER} !duckduckgo\. [NC]
  RewriteCond %{HTTP_REFERER} !facebook\. [NC]
  RewriteCond %{HTTP_REFERER} !instagram\. [NC]
  RewriteCond %{HTTP_REFERER} !linkedin\. [NC]
  RewriteCond %{HTTP_REFERER} !(twitter|x)\. [NC]
  RewriteCond %{HTTP_REFERER} !whatsapp\. [NC]
  RewriteCond %{HTTP_REFERER} !t\.co [NC]
  RewriteRule \.(jpe?g|png|webp|gif)$ - [F,NC,L]
</IfModule>

# Correct MIME types
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType image/webp .webp
  AddType font/woff2 .woff2
  AddType image/svg+xml .svg
</IfModule>
